{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline --theme=nord --config ~/.config/claude-powerline/config.json"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Constructing the point",
      "Lining up the bottles",
      "Creating your own calm",
      "One point at a time",
      "Enjoying the suffering"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
